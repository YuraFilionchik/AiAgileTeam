{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TokenPricing": {

    "Models": {
      "default": {
        "PromptPer1K": 0,
        "CompletionPer1K": 0
      },
      "gpt-4o": {
        "PromptPer1K": 0.005,
        "CompletionPer1K": 0.015
      },
      "gpt-4o-mini": {
        "PromptPer1K": 0.00015,
        "CompletionPer1K": 0.0006
      }
    },
    "GeminiPricing": {
      "Currency": "USD",
      "PerMillionTokens": true,
      "Models": {
        "gemini-2.5-pro": {
          "Input": {
            "PromptsUpTo200k": 1.25,
            "PromptsOver200k": 2.50
          },
          "Output": {
            "PromptsUpTo200k": 10.00,
            "PromptsOver200k": 15.00
          },
          "ContextCaching": {
            "Write": {
              "PromptsUpTo200k": 0.125,
              "PromptsOver200k": 0.25
            },
            "StoragePerHourPerMillion": 4.50
          },
          "Notes": "Multimodal, strong reasoning & coding"
        },
        "gemini-2.5-flash": {
          "Input": {
            "TextImageVideo": 0.30,
            "Audio": 1.00
          },
          "Output": 2.50,
          "ContextCaching": {
            "Write": {
              "TextImageVideo": 0.03,
              "Audio": 0.10
            },
            "StoragePerHourPerMillion": 1.00
          },
          "Notes": "1M context, hybrid reasoning, fastest in family"
        },
        "gemini-2.5-flash-lite": {
          "Input": {
            "TextImageVideo": 0.10,
            "Audio": 0.30
          },
          "Output": 0.40,
          "ContextCaching": {
            "Write": {
              "TextImageVideo": 0.01,
              "Audio": 0.03
            },
            "StoragePerHourPerMillion": 1.00
          },
          "Notes": "Most cost-effective large context model"
        },
        "gemini-2.0-flash": {
          "Input": {
            "TextImageVideo": 0.10,
            "Audio": 0.70
          },
          "Output": 0.40,
          "ContextCaching": {
            "Write": {
              "TextImageVideo": 0.025,
              "Audio": 0.175
            },
            "StoragePerHourPerMillion": 1.00
          },
          "Notes": "1M context, very low cost"
        },
        "gemini-2.0-flash-lite": {
          "Input": {
            "TextImageVideo": 0.075
          },
          "Output": 0.30,
          "Notes": "Smallest & cheapest model"
        },
        "gemini-3.1-pro-preview": {
          "Input": {
            "PromptsUpTo200k": 2.00,
            "PromptsOver200k": 4.00
          },
          "Output": {
            "PromptsUpTo200k": 12.00,
            "PromptsOver200k": 18.00
          },
          "ContextCaching": {
            "Write": {
              "PromptsUpTo200k": 0.20,
              "PromptsOver200k": 0.40
            },
            "StoragePerHourPerMillion": 4.50
          },
          "Notes": "Agentic capabilities, multimodal"
        },
        "gemini-3-flash-preview": {
          "Input": {
            "TextImageVideo": 0.50,
            "Audio": 1.00
          },
          "Output": 3.00,
          "ContextCaching": {
            "Write": {
              "TextImageVideo": 0.05,
              "Audio": 0.10
            },
            "StoragePerHourPerMillion": 1.00
          }
        }
      }
    },
    "MediaStorage": {
      "Provider": "InMemory",
      "ContainerName": "agent-media",
      "ConnectionString": ""
    }
