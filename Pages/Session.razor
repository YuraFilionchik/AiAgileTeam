@page "/session"
@using System.Net.Http.Json
@using AiAgileTeam.Models
@inject SettingsService SettingsService
@inject NavigationManager NavigationManager
@inject IHttpClientFactory HttpClientFactory

<MudText Typo="Typo.h5" GutterBottom="true">Session</MudText>

@if (_isInitializing)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <ChatLog Messages="_messages" />

    @if (!_isSessionComplete)
    {
        <MudCard Class="mt-4">
            <MudCardContent>
                <MudTextField @bind-Value="_userInput" Label="Reply..." Lines="3" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2" OnClick="SendMessage" Disabled="_isProcessing">
                    Send
                </MudButton>
            </MudCardContent>
        </MudCard>
    }
}

@code {
    [SupplyParameterFromQuery]
    public string Query { get; set; }

    [SupplyParameterFromQuery]
    public bool Clarify { get; set; }

    private AppSettings _settings;
    private List<ChatMessage> _messages = new();
    private string _userInput = "";
    private bool _isInitializing = true;
    private bool _isProcessing = false;
    private bool _isSessionComplete = false;
    private bool _clarificationPhase = false;
    private int _clarificationQuestionsAsked = 0;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.LoadSettingsAsync();
        
        if (string.IsNullOrWhiteSpace(Query))
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        await InitializeSessionAsync();
    }

    private async Task ProcessApiStream(HttpResponseMessage response)
    {
        response.EnsureSuccessStatusCode();
        var stream = await response.Content.ReadAsStreamAsync();
        
        string currentAuthor = "";
        ChatMessage uiMessage = null;

        await foreach (var message in System.Text.Json.JsonSerializer.DeserializeAsyncEnumerable<StreamingMessageDto>(stream, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }))
        {
            if (message == null) continue;

            if (currentAuthor != message.Author || uiMessage == null)
            {
                currentAuthor = message.Author;
                uiMessage = new ChatMessage { Author = currentAuthor, Content = "", IsUser = false };
                _messages.Add(uiMessage);
            }

            uiMessage.Content += message.ContentPiece;
            StateHasChanged();

            if (message.IsComplete)
            {
                // Handle next steps logic if needed based on readiness
                if (_clarificationPhase && (uiMessage.Content.Contains("[READY]") || _clarificationQuestionsAsked >= 2))
                {
                    _clarificationPhase = false;
                    _messages.Add(new ChatMessage { Author = "System", Content = "Clarification complete. Starting team discussion...", IsUser = false });
                    StateHasChanged();
                    await StartTeamDiscussionAsync();
                    return; // Break out of processing clarification stream as we just fired a new stream
                }
            }
        }
        
        if (_clarificationPhase)
        {
             _clarificationQuestionsAsked++;
        }
    }

    private async Task InitializeSessionAsync()
    {
        try
        {
            _isProcessing = true;
            _messages.Add(new ChatMessage { Author = "User", Content = Query, IsUser = true });
            
            _clarificationPhase = Clarify;
            
            var request = new SessionRequest
            {
                Query = Query,
                Clarify = Clarify,
                Settings = _settings
            };

            using var httpClient = HttpClientFactory.CreateClient("ApiClient");
            var response = await httpClient.PostAsJsonAsync("api/aiteam/session", request);
            
            await ProcessApiStream(response);

            if (!Clarify) 
            {
                _isSessionComplete = true; // For MVP if no clarification, the first stream handles discussion and completes
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage { Author = "System", Content = $"Error initializing session: {ex.Message}", IsUser = false });
        }
        finally
        {
            _isProcessing = false;
            _isInitializing = false;
            StateHasChanged();
        }
    }

    private async Task StartTeamDiscussionAsync()
    {
         var request = new SessionRequest
         {
             Query = Query, // For a real implementation, we would send the full conversation history. MVP constraint.
             Clarify = false, // Force false to trigger discussion logic
             Settings = _settings
         };
         
         using var httpClient = HttpClientFactory.CreateClient("ApiClient");
         // Since we already did initialization via /session, we just use /message, passing false for clarification phase.
         var response = await httpClient.PostAsJsonAsync($"api/aiteam/message?isClarificationPhase=false", request);
         await ProcessApiStream(response);
         _isSessionComplete = true;
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_userInput)) return;

        var message = _userInput;
        _userInput = "";
        _isProcessing = true;
        
        _messages.Add(new ChatMessage { Author = "User", Content = message, IsUser = true });
        StateHasChanged();

        try
        {
            var request = new SessionRequest
            {
                Query = message, // For MVP, we're just sending the latest message
                Settings = _settings
            };

            using var httpClient = HttpClientFactory.CreateClient("ApiClient");
            var response = await httpClient.PostAsJsonAsync($"api/aiteam/message?isClarificationPhase={_clarificationPhase}", request);
            await ProcessApiStream(response);
            
            if (!_clarificationPhase)
            {
                _isSessionComplete = true;
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage { Author = "System", Content = $"Error: {ex.Message}", IsUser = false });
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}
